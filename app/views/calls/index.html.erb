<%= turbo_stream_from "calls" %>

<div class="flex flex-col items-center gap-8 min-w-[700px]">
    <h1 class="text-3xl font-semibold">Calls</h1>
    
    <table class="min-w-full">
        <thead class="border-b border-zinc-700">
            <tr>
                <th scope="col" class="p-3 text-left text-xs font-medium text-gray-500 uppercase text-neutral-500">Id</th>
                <th scope="col" class="p-3 text-left text-xs font-medium text-gray-500 uppercase text-neutral-500">Duration</th>
                <th scope="col" class="p-3 text-left text-xs font-medium text-gray-500 uppercase text-neutral-500">Status</th>
                <th scope="col" class="text-left text-xs font-medium text-gray-500 uppercase text-neutral-500 w-[100px]">Recording</th>
            </tr>
        </thead>
        <tbody id="calls_content" class="divide-y divide-gray-200 divide-neutral-700">
            <% @calls.each do |call| %>
                <%= render "table_content", call: call %>
            <% end %>
        </tbody>
    </table>
</div>